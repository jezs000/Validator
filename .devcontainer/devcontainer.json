{
  "name": "OCR Invoice Validator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [8501],
  "postCreateCommand": "pip install -r requirements.txt",
  "postStartCommand": "streamlit run app.py --server.port=8501 --server.address=0.0.0.0",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "remoteUser": "vscode"
}
